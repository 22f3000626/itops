# ── LLM provider selection ─────────────────────────────────
# Which provider the agents should use: ollama | openai | gemini
# This is only the default on first boot; the runtime value is stored
# in backend/runtime_settings.json and can be changed from the Settings UI.
LLM_PROVIDER=ollama

# ── Ollama (local, free) ───────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
# LLM Model for agents (default: llama3.2:3b - faster)
# Alternatives: qwen2.5-coder:7b, mistral-nemo, deepseek-coder-v2, gemma3:4b
OLLAMA_MODEL=llama3.2:3b
# Embedding Model for RAG (default: nomic-embed-text).
# Embeddings always use Ollama regardless of the active chat provider.
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ── OpenAI (optional, cloud) ───────────────────────────────
# Used only when LLM_PROVIDER=openai or when the Settings UI selects it.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Google Gemini (optional, cloud) ────────────────────────
# Used only when LLM_PROVIDER=gemini or when the Settings UI selects it.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Database URL (default: SQLite in project root)
# DATABASE_URL=sqlite:///./itops.db

# Simulator settings
SIMULATOR_INTERVAL_SECONDS=10
NUM_SIMULATED_SERVERS=6
ANOMALY_PROBABILITY=0.15

# Auto-approve remediations for these severity levels (comma-separated)
# Anything not listed requires human-in-the-loop approval
REMEDIATION_AUTO_APPROVE_SEVERITY=low,medium

# Agent LLM temperature (0.0 = deterministic, 1.0 = creative)
AGENT_TEMPERATURE=0.1

# Comma-separated origins allowed by CORS. Use "*" only for internal dev —
# when set to "*", allow_credentials is forced off per the CORS spec.
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Max concurrent agent pipelines spawned by the monitoring / auto-run loops.
# Guards the event loop and the DB writer during anomaly storms.
PIPELINE_MAX_CONCURRENT=4
