# OpenAI API Key (required for agent LLM calls)
OPENAI_API_KEY=sk-your-key-here

# Model to use (default: gpt-4o-mini for cost efficiency; use gpt-4o for best quality)
OPENAI_MODEL=gpt-4o-mini

# Database URL (default: SQLite in project root)
# DATABASE_URL=sqlite:///./itops.db

# Simulator settings
SIMULATOR_INTERVAL_SECONDS=10
NUM_SIMULATED_SERVERS=6
ANOMALY_PROBABILITY=0.15

# Auto-approve remediations for these severity levels (comma-separated)
# Anything not listed requires human-in-the-loop approval
REMEDIATION_AUTO_APPROVE_SEVERITY=low,medium

# Agent LLM temperature (0.0 = deterministic, 1.0 = creative)
AGENT_TEMPERATURE=0.1
